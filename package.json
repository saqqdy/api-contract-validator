{
  "name": "api-contract-validator",
  "description": "AI-powered API contract validator — detect drift between OpenAPI spec and implementation. Semantic validation via Claude Code Skill",
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.9",
  "bin": {
    "api-contract-validator": "./dist/cli.js"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    ".claude",
    ".claude-plugin",
    "README.md",
    "README_CN.md",
    "CHANGELOG.md",
    "LICENSE",
    "examples"
  ],
  "scripts": {
    "build": "run-s clean build:bundle build:types",
    "build:bundle": "tsup",
    "build:types": "tsc --emitDeclarationOnly",
    "clean": "rm-all dist",
    "dev": "tsup --watch",
    "lint": "eslint --fix .",
    "prettier": "prettier --write \"**/*.{js,ts,mjs,yml,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dist": "run-s lint build",
    "typecheck": "tsc --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "js-yaml": "^4.3.0"
  },
  "devDependencies": {
    "@eslint-sets/eslint-config": "^6.3.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "3.2.6",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.1",
    "prettier-config-common": "^1.5.0",
    "rm-all": "^1.1.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=18.20"
  },
  "sideEffects": [
    "**/analyzer/*.ts"
  ],
  "keywords": [
    "api-contract-validator",
    "openapi",
    "swagger",
    "contract-drift",
    "api-validation",
    "spec-validation",
    "claude-code",
    "claude-code-skill"
  ],
  "license": "MIT",
  "author": "saqqdy<https://github.com/saqqdy>",
  "homepage": "https://github.com/saqqdy/api-contract-validator#readme",
  "bugs": {
    "url": "https://github.com/saqqdy/api-contract-validator/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saqqdy/api-contract-validator.git"
  }
}